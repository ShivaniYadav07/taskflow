PORT=8000
MONGO_URI=mongodb://localhost:27017/task_manager

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters — server will refuse to start otherwise
JWT_SECRET=replace_this_with_a_64_char_random_hex_string

JWT_EXPIRES_IN=7d
NODE_ENV=development

# Must match the exact frontend URL (no trailing slash)
# In production: set to your Vercel deployment URL
CLIENT_URL=http://localhost:3000

# Server-side only — used by Next.js rewrites to proxy /api/* to Express
# Set this in client/.env.local as: API_URL=http://localhost:8000
# In production: set to your Render backend URL (no /api suffix)
# API_URL=http://localhost:8000
